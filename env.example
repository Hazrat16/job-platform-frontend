# API: leave unset so the browser uses same-origin /api (Next.js rewrites to backend).
# Or set full URL if the frontend and API are on different hosts.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000/api

# Where Next dev server proxies /api/* (default matches backend PORT=5000)
# API_PROXY_TARGET=http://127.0.0.1:5000

# Authentication (if using NextAuth.js)
# NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=http://localhost:3000

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
# NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_CHAT=true
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
